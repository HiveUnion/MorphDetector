<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 标题说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="KeyEvent 删除键检测"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测 input keyevent 67 (KEYCODE_DEL) 注入 vs 真实删除。\n\n测试方式：\n1. 执行 input keyevent 67 → 应被检测为注入\n2. 点击输入框用软键盘删除 → 应为正常\n3. 用物理键盘 Delete → 应为正常"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 输入框区域 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="测试输入框"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="点击输入框获取焦点，然后用不同方式触发删除"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etInputArea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:padding="12dp"
                        android:background="@drawable/section_background"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:hint="输入文本后测试删除..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 实时检测结果 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测结果"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />

                    <!-- 判定结论 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvVerdict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待删除事件..."
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:padding="16dp"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 详细参数 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvEventDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="请在输入框中触发删除操作\n\n测试方式：\n1. input keyevent 67 (注入)\n2. 软键盘删除键 (正常)\n3. 物理键盘 Delete (正常)"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant"
                            android:padding="16dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 历史记录 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="历史记录"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <Button
                            android:id="@+id/btnClearHistory"
                            style="@style/Widget.TestAutoJs.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/button_primary_ripple"
                            android:text="清空"
                            android:textSize="12sp"
                            android:textColor="@color/on_primary"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="暂无记录"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:padding="16dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 检测原理说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测原理"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. source: 注入=SOURCE_KEYBOARD(257)\n2. deviceId: 注入=0/-1, 真实=非零物理设备ID\n3. flags: 软键盘带 FLAG_SOFT_KEYBOARD\n4. eventTime-downTime: 注入=0ms, 真实>0ms\n5. scanCode: 注入=0, 真实物理按键=非零\n\n关键区别：\n- input keyevent 67: 产生 KeyEvent，可被检测\n- 软键盘删除: 多数走 InputConnection，不产生 KeyEvent\n- ACTION_SET_TEXT: 走无障碍API，不产生 KeyEvent"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
