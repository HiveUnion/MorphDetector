<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 标题说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="KeyEvent 粘贴键检测"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测所有粘贴路径，对比参数差异。\n\n测试方式：\n1. input keyevent 279 → KeyEvent 注入\n2. 物理键盘 Ctrl+V → KeyEvent 真实\n3. 长按菜单粘贴 → ContextMenu 路径\n4. performAction(ACTION_PASTE) → ContextMenu 路径\n\n路径 1/2 有完整 KeyEvent 参数，路径 3/4 仅有 menuItemId。"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 输入框区域 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="测试输入框"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="点击输入框获取焦点，然后用不同方式触发粘贴"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="8dp" />

                    <com.example.testauto.PasteMonitorEditText
                        android:id="@+id/etInputArea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:padding="12dp"
                        android:background="@drawable/section_background"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:hint="点击此处获取焦点，然后触发粘贴..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 剪贴板状态 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="剪贴板监控"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvClipboardInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待剪贴板变化..."
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant"
                            android:padding="16dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 实时检测结果 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测结果"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />

                    <!-- 判定结论 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvVerdict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待粘贴事件..."
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:padding="16dp"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 详细参数 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvEventDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="请在输入框中触发粘贴操作\n\n测试方式：\n1. input keyevent KEYCODE_PASTE (注入)\n2. input keyevent 279 (注入)\n3. 长按菜单粘贴 (正常)\n4. 物理键盘 Ctrl+V (正常)"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant"
                            android:padding="16dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 历史记录 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="历史记录"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <Button
                            android:id="@+id/btnClearHistory"
                            style="@style/Widget.TestAutoJs.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/button_primary_ripple"
                            android:text="清空"
                            android:textSize="12sp"
                            android:textColor="@color/on_primary"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider">

                        <TextView
                            android:id="@+id/tvHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="暂无记录"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant"
                            android:padding="16dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 检测原理说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测原理"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="路径 A — KeyEvent (input keyevent 279 / Ctrl+V):\n  走 dispatchKeyEvent，有完整参数：\n  source, deviceId, scanCode, flags,\n  pressDuration, metaState, repeatCount\n  注入特征: deviceId=-1, scanCode=0, press=0ms\n\n路径 B — ContextMenu (长按粘贴 / ACTION_PASTE):\n  走 onTextContextMenuItem，仅有：\n  menuItemId (paste / pasteAsPlainText)\n  剪贴板内容 + 时间戳\n  无 KeyEvent 参数，无法从参数检测注入\n\n共同检测维度：\n  剪贴板时序: copy→paste &lt;100ms 疑似自动化\n\n关键结论：\n  input keyevent 279 — 有注入特征，可被检测\n  长按粘贴 — 无 KeyEvent，无法检测\n  performAction(ACTION_PASTE) — 同长按粘贴路径"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
